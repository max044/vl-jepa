# ═══════════════════════════════════════════════════════════
# VL-JEPA Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── W&B (Weights & Biases) ─────────────────────────────────
# Get your API key at: https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=vl-jepa
# WANDB_ENTITY=your-team-name   # Optional: W&B team/organization

# ── Training Overrides (optional) ──────────────────────────
# EPOCHS=20
# BATCH_SIZE=16
# LR=3e-4
# NUM_WORKERS=4
